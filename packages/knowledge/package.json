{
  "name": "@iacmp/knowledge",
  "version": "2.2.1",
  "license": "MIT",
  "description": "Retrieval compartilhado da knowledge base iacmp (FTS5 + boost) — fonte única para o CLI e o servidor MCP",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "ts-jest": "29.4.11",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  }
}
