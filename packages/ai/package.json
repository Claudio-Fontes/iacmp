{
  "name": "@iacmp/ai",
  "version": "1.2.0",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "jest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@iacmp/core": "*",
    "chalk": "^4.1.2",
    "diff": "^5.2.0",
    "openai": "6.45.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "ts-jest": "29.4.11",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "testTimeout": 15000,
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  }
}
