{
  "terraform": {
    "required_providers": {
      "google": {
        "source": "hashicorp/google",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "google": {
      "project": "${var.project_id}",
      "region": "${var.gcp_region}"
    }
  },
  "variable": {
    "project_id": {
      "type": "string"
    },
    "gcp_region": {
      "type": "string",
      "default": "us-central1"
    },
    "gcp_zone": {
      "type": "string",
      "default": "us-central1-a"
    }
  },
  "resource": {
    "google_compute_network": {
      "appvpc": {
        "name": "appvpc",
        "auto_create_subnetworks": false,
        "routing_mode": "REGIONAL"
      }
    },
    "google_compute_subnetwork": {
      "privatesubnet1": {
        "name": "privatesubnet1",
        "network": "${google_compute_network.appvpc.id}",
        "ip_cidr_range": "10.0.1.0/24",
        "region": "${var.gcp_region}",
        "private_ip_google_access": true
      },
      "privatesubnet2": {
        "name": "privatesubnet2",
        "network": "${google_compute_network.appvpc.id}",
        "ip_cidr_range": "10.0.2.0/24",
        "region": "${var.gcp_region}",
        "private_ip_google_access": true
      }
    },
    "google_compute_instance": {
      "webserver": {
        "name": "webserver",
        "machine_type": "e2-small",
        "zone": "${var.gcp_zone}",
        "boot_disk": [
          {
            "initialize_params": [
              {
                "image": "projects/ubuntu-os-cloud/global/images/family/ubuntu-2204-lts"
              }
            ]
          }
        ],
        "network_interface": [
          {
            "network": "default"
          }
        ]
      }
    },
    "google_compute_instance_template": {
      "appfleet_template": {
        "name": "appfleet-template",
        "machine_type": "e2-medium",
        "disk": [
          {
            "source_image": "projects/ubuntu-os-cloud/global/images/family/ubuntu-2204-lts"
          }
        ],
        "network_interface": [
          {
            "network": "default"
          }
        ]
      }
    },
    "google_compute_region_instance_group_manager": {
      "appfleet": {
        "name": "appfleet",
        "base_instance_name": "appfleet",
        "region": "${var.gcp_region}",
        "version": [
          {
            "instance_template": "${google_compute_instance_template.appfleet_template.id}"
          }
        ],
        "target_size": 2
      }
    },
    "google_compute_region_autoscaler": {
      "appfleet_autoscaler": {
        "name": "appfleet-autoscaler",
        "region": "${var.gcp_region}",
        "target": "${google_compute_region_instance_group_manager.appfleet.id}",
        "autoscaling_policy": [
          {
            "min_replicas": 2,
            "max_replicas": 6,
            "cooldown_period": 60,
            "cpu_utilization": [
              {
                "target": 0.6
              }
            ]
          }
        ]
      }
    },
    "google_cloud_run_v2_service": {
      "apiservice": {
        "name": "ApiService",
        "location": "${var.gcp_region}",
        "template": [
          {
            "containers": [
              {
                "image": "gcr.io/proj/api:latest",
                "resources": [
                  {
                    "limits": {
                      "cpu": "1",
                      "memory": "1024Mi"
                    }
                  }
                ],
                "ports": [
                  {
                    "container_port": 8080
                  }
                ],
                "env": [
                  {
                    "name": "NODE_ENV",
                    "value": "production"
                  }
                ]
              }
            ],
            "scaling": [
              {
                "min_instance_count": 0,
                "max_instance_count": 2
              }
            ]
          }
        ],
        "ingress": "INGRESS_TRAFFIC_ALL"
      }
    },
    "google_container_cluster": {
      "appcluster": {
        "name": "appcluster",
        "location": "${var.gcp_region}",
        "initial_node_count": 3,
        "node_config": [
          {
            "machine_type": "e2-standard-4"
          }
        ],
        "enable_autopilot": false,
        "private_cluster_config": [
          {
            "enable_private_nodes": true,
            "enable_private_endpoint": false,
            "master_ipv4_cidr_block": "172.16.0.32/28"
          }
        ]
      }
    }
  }
}
