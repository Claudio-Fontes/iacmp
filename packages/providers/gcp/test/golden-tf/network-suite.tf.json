{
  "terraform": {
    "required_providers": {
      "google": {
        "source": "hashicorp/google",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "google": {
      "project": "${var.project_id}",
      "region": "${var.gcp_region}"
    }
  },
  "variable": {
    "project_id": {
      "type": "string"
    },
    "gcp_region": {
      "type": "string",
      "default": "us-central1"
    }
  },
  "resource": {
    "google_compute_network": {
      "appvpc": {
        "name": "appvpc",
        "auto_create_subnetworks": false,
        "routing_mode": "REGIONAL"
      }
    },
    "google_compute_subnetwork": {
      "publicsubnet1": {
        "name": "publicsubnet1",
        "network": "${google_compute_network.appvpc.id}",
        "ip_cidr_range": "10.0.1.0/24",
        "region": "${var.gcp_region}",
        "private_ip_google_access": false
      },
      "publicsubnet2": {
        "name": "publicsubnet2",
        "network": "${google_compute_network.appvpc.id}",
        "ip_cidr_range": "10.0.2.0/24",
        "region": "${var.gcp_region}",
        "private_ip_google_access": false
      }
    },
    "google_compute_firewall": {
      "albsg_ingress_0": {
        "name": "albsg-ingress-0",
        "network": "${google_compute_network.appvpc.id}",
        "direction": "INGRESS",
        "priority": 1000,
        "allow": [
          {
            "protocol": "tcp",
            "ports": [
              "443"
            ]
          }
        ],
        "source_ranges": [
          "0.0.0.0/0"
        ]
      },
      "albsg_egress_0": {
        "name": "albsg-egress-0",
        "network": "${google_compute_network.appvpc.id}",
        "direction": "EGRESS",
        "priority": 1000,
        "allow": [
          {
            "protocol": "all"
          }
        ],
        "destination_ranges": [
          "0.0.0.0/0"
        ]
      }
    },
    "google_compute_backend_service": {
      "applb_backend": {
        "name": "applb-backend",
        "protocol": "HTTP",
        "load_balancing_scheme": "EXTERNAL"
      }
    },
    "google_compute_url_map": {
      "applb_url_map": {
        "name": "applb-url-map",
        "default_service": "${google_compute_backend_service.applb_backend.id}"
      },
      "assetscdn_url_map": {
        "name": "assetscdn-url-map",
        "default_service": "${google_compute_backend_bucket.assetscdn_backend_bucket.id}"
      }
    },
    "google_compute_target_http_proxy": {
      "applb_http_proxy": {
        "name": "applb-http-proxy",
        "url_map": "${google_compute_url_map.applb_url_map.id}"
      }
    },
    "google_compute_global_forwarding_rule": {
      "applb_forwarding_rule": {
        "name": "applb-forwarding-rule",
        "target": "${google_compute_target_http_proxy.applb_http_proxy.id}",
        "port_range": "80",
        "load_balancing_scheme": "EXTERNAL"
      }
    },
    "google_compute_backend_bucket": {
      "assetscdn_backend_bucket": {
        "name": "assetscdn-backend-bucket",
        "bucket_name": "assets-bucket-name",
        "enable_cdn": true
      }
    },
    "google_dns_managed_zone": {
      "example_com_zone": {
        "name": "example-com-zone",
        "dns_name": "example.com.",
        "visibility": "public"
      }
    },
    "google_dns_record_set": {
      "example_com_records": {
        "name": "example.com.",
        "managed_zone": "${google_dns_managed_zone.example_com_zone.name}",
        "type": "A",
        "ttl": 300,
        "rrdatas": [
          "1.2.3.4"
        ]
      }
    },
    "google_compute_security_policy": {
      "apiwaf": {
        "name": "apiwaf",
        "rule": [
          {
            "priority": 1,
            "action": "allow",
            "match": {
              "versioned_expr": "SRC_IPS_V1",
              "config": [
                {
                  "src_ip_ranges": [
                    "*"
                  ]
                }
              ]
            },
            "description": ""
          },
          {
            "priority": 2,
            "action": "allow",
            "match": {
              "expr": [
                {
                  "expression": "evaluatePreconfiguredExpr(\"sqli-stable\")"
                }
              ]
            },
            "description": ""
          },
          {
            "priority": 2147483647,
            "action": "allow",
            "match": {
              "versioned_expr": "SRC_IPS_V1",
              "config": [
                {
                  "src_ip_ranges": [
                    "*"
                  ]
                }
              ]
            },
            "description": "Default rule"
          }
        ]
      }
    }
  }
}
