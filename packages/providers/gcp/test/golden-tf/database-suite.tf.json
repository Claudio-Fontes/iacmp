{
  "terraform": {
    "required_providers": {
      "google": {
        "source": "hashicorp/google",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "google": {
      "project": "${var.project_id}",
      "region": "${var.gcp_region}"
    }
  },
  "variable": {
    "project_id": {
      "type": "string"
    },
    "gcp_region": {
      "type": "string",
      "default": "us-central1"
    },
    "gcp_zone": {
      "type": "string",
      "default": "us-central1-a"
    }
  },
  "resource": {
    "google_sql_database_instance": {
      "maindb": {
        "name": "MainDb",
        "database_version": "POSTGRES_15",
        "region": "${var.gcp_region}",
        "settings": [
          {
            "tier": "db-f1-micro",
            "backup_configuration": [
              {
                "enabled": true
              }
            ],
            "availability_type": "REGIONAL"
          }
        ],
        "deletion_protection": false
      }
    },
    "google_bigtable_instance": {
      "itemstable": {
        "name": "itemstable",
        "cluster": [
          {
            "cluster_id": "cluster-1",
            "zone": "${var.gcp_zone}",
            "num_nodes": 1,
            "storage_type": "SSD"
          }
        ],
        "instance_type": "PRODUCTION",
        "display_name": "ItemsTable"
      }
    },
    "google_firestore_database": {
      "docsdb": {
        "project": "${var.project_id}",
        "name": "(default)",
        "location_id": "${var.gcp_region}",
        "type": "FIRESTORE_NATIVE",
        "deletion_policy": "DELETE_PROTECTION_ENABLED"
      }
    },
    "google_redis_instance": {
      "sessioncache": {
        "name": "sessioncache",
        "tier": "STANDARD_HA",
        "memory_size_gb": 5,
        "region": "${var.gcp_region}",
        "redis_version": "REDIS_7_0",
        "auth_enabled": true,
        "transit_encryption_mode": "SERVER_AUTHENTICATION"
      }
    },
    "google_memcache_instance": {
      "objectcache": {
        "name": "objectcache",
        "region": "${var.gcp_region}",
        "node_count": 3,
        "node_config": [
          {
            "cpu_count": 1,
            "memory_size_mb": 1024
          }
        ]
      }
    },
    "google_secret_manager_secret": {
      "dbcredentials": {
        "secret_id": "DbCredentials",
        "replication": [
          {
            "auto": [
              {}
            ]
          }
        ]
      }
    },
    "google_certificate_manager_certificate": {
      "apicert": {
        "name": "ApiCert",
        "managed": [
          {
            "domains": [
              "api.example.com",
              "www.example.com"
            ]
          }
        ]
      }
    }
  },
  "output": {
    "MainDbConnectionName": {
      "value": "${google_sql_database_instance.maindb.connection_name}"
    },
    "SessionCacheRedisHost": {
      "value": "${google_redis_instance.sessioncache.host}"
    },
    "SessionCacheRedisPort": {
      "value": "${google_redis_instance.sessioncache.port}"
    },
    "DbCredentialsSecretName": {
      "value": "${google_secret_manager_secret.dbcredentials.secret_id}"
    }
  }
}
