{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Stack waf-rest-api — gerada pelo iacmp",
  "Resources": {
    "ApiWaf": {
      "Type": "AWS::WAFv2::WebACL",
      "Properties": {
        "Name": "ApiWaf",
        "Scope": "REGIONAL",
        "DefaultAction": {
          "Allow": {}
        },
        "Description": "WAF ApiWaf",
        "Rules": [
          {
            "Name": "RateLimit",
            "Priority": 1,
            "Action": {
              "Block": {}
            },
            "VisibilityConfig": {
              "SampledRequestsEnabled": true,
              "CloudWatchMetricsEnabled": true,
              "MetricName": "RateLimit"
            },
            "Statement": {
              "RateBasedStatement": {
                "Limit": 1000,
                "AggregateKeyType": "IP"
              }
            }
          },
          {
            "Name": "CommonRules",
            "Priority": 2,
            "OverrideAction": {
              "None": {}
            },
            "VisibilityConfig": {
              "SampledRequestsEnabled": true,
              "CloudWatchMetricsEnabled": true,
              "MetricName": "CommonRules"
            },
            "Statement": {
              "ManagedRuleGroupStatement": {
                "VendorName": "AWS",
                "Name": "AWSManagedRulesCommonRuleSet"
              }
            }
          }
        ],
        "VisibilityConfig": {
          "SampledRequestsEnabled": true,
          "CloudWatchMetricsEnabled": true,
          "MetricName": "ApiWaf"
        }
      }
    },
    "ApiHandlerDefaultRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      }
    },
    "ApiHandler": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "FunctionName": "ApiHandler",
        "Runtime": "nodejs20.x",
        "Handler": "index.handler",
        "Code": "dist/",
        "MemorySize": 128,
        "Timeout": 30,
        "Role": {
          "Fn::GetAtt": [
            "ApiHandlerDefaultRole",
            "Arn"
          ]
        }
      }
    },
    "RestApi": {
      "Type": "AWS::ApiGateway::RestApi",
      "Properties": {
        "Name": "waf-api"
      }
    },
    "RestApiResourceitems": {
      "Type": "AWS::ApiGateway::Resource",
      "Properties": {
        "RestApiId": {
          "Ref": "RestApi"
        },
        "ParentId": {
          "Fn::GetAtt": [
            "RestApi",
            "RootResourceId"
          ]
        },
        "PathPart": "items"
      }
    },
    "RestApiGETitemsMethod": {
      "Type": "AWS::ApiGateway::Method",
      "Properties": {
        "RestApiId": {
          "Ref": "RestApi"
        },
        "ResourceId": {
          "Ref": "RestApiResourceitems"
        },
        "HttpMethod": "GET",
        "AuthorizationType": "NONE",
        "Integration": {
          "Type": "AWS_PROXY",
          "IntegrationHttpMethod": "POST",
          "Uri": {
            "Fn::Sub": "arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${ApiHandler.Arn}/invocations"
          }
        }
      }
    },
    "RestApiPOSTitemsMethod": {
      "Type": "AWS::ApiGateway::Method",
      "Properties": {
        "RestApiId": {
          "Ref": "RestApi"
        },
        "ResourceId": {
          "Ref": "RestApiResourceitems"
        },
        "HttpMethod": "POST",
        "AuthorizationType": "NONE",
        "Integration": {
          "Type": "AWS_PROXY",
          "IntegrationHttpMethod": "POST",
          "Uri": {
            "Fn::Sub": "arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${ApiHandler.Arn}/invocations"
          }
        }
      }
    },
    "RestApiDeploymente11612c6": {
      "Type": "AWS::ApiGateway::Deployment",
      "DependsOn": [
        "RestApiGETitemsMethod",
        "RestApiPOSTitemsMethod"
      ],
      "Properties": {
        "RestApiId": {
          "Ref": "RestApi"
        }
      }
    },
    "RestApiStage": {
      "Type": "AWS::ApiGateway::Stage",
      "Properties": {
        "RestApiId": {
          "Ref": "RestApi"
        },
        "DeploymentId": {
          "Ref": "RestApiDeploymente11612c6"
        },
        "StageName": "prod"
      }
    },
    "RestApiWafAssociation": {
      "Type": "AWS::WAFv2::WebACLAssociation",
      "DependsOn": [
        "RestApiStage"
      ],
      "Properties": {
        "ResourceArn": {
          "Fn::Sub": [
            "arn:aws:apigateway:${AWS::Region}::/restapis/${ApiId}/stages/prod",
            {
              "ApiId": {
                "Ref": "RestApi"
              }
            }
          ]
        },
        "WebACLArn": {
          "Fn::GetAtt": [
            "ApiWaf",
            "Arn"
          ]
        }
      }
    },
    "ApiHandlerRestApiPermission": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "Action": "lambda:InvokeFunction",
        "FunctionName": {
          "Fn::GetAtt": [
            "ApiHandler",
            "Arn"
          ]
        },
        "Principal": "apigateway.amazonaws.com",
        "SourceArn": {
          "Fn::Sub": "arn:aws:execute-api:${AWS::Region}:${AWS::AccountId}:${RestApi}/*/*"
        }
      }
    }
  },
  "Outputs": {
    "ApiWafArn": {
      "Value": {
        "Fn::GetAtt": [
          "ApiWaf",
          "Arn"
        ]
      },
      "Export": {
        "Name": "waf-rest-api-ApiWaf-Arn"
      }
    },
    "ApiHandlerArn": {
      "Value": {
        "Fn::GetAtt": [
          "ApiHandler",
          "Arn"
        ]
      },
      "Export": {
        "Name": "waf-rest-api-ApiHandler-Arn"
      }
    }
  }
}
