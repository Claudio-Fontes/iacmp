{
  "rs-infra": {
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "Stack rs-infra — gerada pelo iacmp",
    "Resources": {
      "AppVpc": {
        "Type": "AWS::EC2::VPC",
        "Properties": {
          "CidrBlock": "10.0.0.0/16",
          "EnableDnsHostnames": true,
          "EnableDnsSupport": true,
          "Tags": [
            {
              "Key": "Name",
              "Value": "AppVpc"
            }
          ]
        }
      },
      "DbSubnet1": {
        "Type": "AWS::EC2::Subnet",
        "Properties": {
          "VpcId": {
            "Ref": "AppVpc"
          },
          "CidrBlock": "10.0.1.0/24",
          "AvailabilityZone": "us-east-1a",
          "MapPublicIpOnLaunch": false,
          "Tags": [
            {
              "Key": "Name",
              "Value": "DbSubnet1"
            },
            {
              "Key": "Type",
              "Value": "private"
            }
          ]
        }
      },
      "DbSubnet2": {
        "Type": "AWS::EC2::Subnet",
        "Properties": {
          "VpcId": {
            "Ref": "AppVpc"
          },
          "CidrBlock": "10.0.2.0/24",
          "AvailabilityZone": "us-east-1b",
          "MapPublicIpOnLaunch": false,
          "Tags": [
            {
              "Key": "Name",
              "Value": "DbSubnet2"
            },
            {
              "Key": "Type",
              "Value": "private"
            }
          ]
        }
      },
      "LambdaSubnet1": {
        "Type": "AWS::EC2::Subnet",
        "Properties": {
          "VpcId": {
            "Ref": "AppVpc"
          },
          "CidrBlock": "10.0.3.0/24",
          "AvailabilityZone": "us-east-1c",
          "MapPublicIpOnLaunch": false,
          "Tags": [
            {
              "Key": "Name",
              "Value": "LambdaSubnet1"
            },
            {
              "Key": "Type",
              "Value": "private"
            }
          ]
        }
      },
      "DbSg": {
        "Type": "AWS::EC2::SecurityGroup",
        "Properties": {
          "GroupDescription": "db",
          "VpcId": {
            "Ref": "AppVpc"
          },
          "SecurityGroupIngress": [
            {
              "IpProtocol": "tcp",
              "FromPort": 5432,
              "ToPort": 5432,
              "CidrIp": "10.0.0.0/16"
            }
          ],
          "SecurityGroupEgress": [
            {
              "IpProtocol": "-1",
              "CidrIp": "0.0.0.0/0",
              "Description": "Allow all egress"
            }
          ],
          "Tags": [
            {
              "Key": "Name",
              "Value": "DbSg"
            }
          ]
        }
      },
      "LambdaSg": {
        "Type": "AWS::EC2::SecurityGroup",
        "Properties": {
          "GroupDescription": "lambda",
          "VpcId": {
            "Ref": "AppVpc"
          },
          "SecurityGroupIngress": [],
          "SecurityGroupEgress": [
            {
              "IpProtocol": "-1",
              "CidrIp": "0.0.0.0/0",
              "Description": "Allow all egress"
            }
          ],
          "Tags": [
            {
              "Key": "Name",
              "Value": "LambdaSg"
            }
          ]
        }
      }
    },
    "Outputs": {
      "AppVpcVpcId": {
        "Value": {
          "Ref": "AppVpc"
        },
        "Export": {
          "Name": "rs-infra-AppVpc-VpcId"
        }
      },
      "DbSubnet1SubnetId": {
        "Value": {
          "Ref": "DbSubnet1"
        },
        "Export": {
          "Name": "rs-infra-DbSubnet1-SubnetId"
        }
      },
      "DbSubnet2SubnetId": {
        "Value": {
          "Ref": "DbSubnet2"
        },
        "Export": {
          "Name": "rs-infra-DbSubnet2-SubnetId"
        }
      },
      "LambdaSubnet1SubnetId": {
        "Value": {
          "Ref": "LambdaSubnet1"
        },
        "Export": {
          "Name": "rs-infra-LambdaSubnet1-SubnetId"
        }
      },
      "DbSgGroupId": {
        "Value": {
          "Fn::GetAtt": [
            "DbSg",
            "GroupId"
          ]
        },
        "Export": {
          "Name": "rs-infra-DbSg-GroupId"
        }
      },
      "LambdaSgGroupId": {
        "Value": {
          "Fn::GetAtt": [
            "LambdaSg",
            "GroupId"
          ]
        },
        "Export": {
          "Name": "rs-infra-LambdaSg-GroupId"
        }
      }
    }
  },
  "rs-db": {
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "Stack rs-db — gerada pelo iacmp",
    "Resources": {
      "AppDBSecret": {
        "Type": "AWS::SecretsManager::Secret",
        "Properties": {
          "Name": "rs-db-AppDB-db-password",
          "GenerateSecretString": {
            "SecretStringTemplate": "{\"username\":\"dbadmin\"}",
            "GenerateStringKey": "password",
            "PasswordLength": 32,
            "ExcludeCharacters": "\"@/\\'"
          }
        }
      },
      "AppDBSubnetGroup": {
        "Type": "AWS::RDS::DBSubnetGroup",
        "Properties": {
          "DBSubnetGroupDescription": "Subnet group para AppDB",
          "SubnetIds": [
            {
              "Fn::ImportValue": "rs-infra-DbSubnet1-SubnetId"
            },
            {
              "Fn::ImportValue": "rs-infra-DbSubnet2-SubnetId"
            }
          ]
        }
      },
      "AppDB": {
        "Type": "AWS::RDS::DBInstance",
        "DeletionPolicy": "Delete",
        "Properties": {
          "DBInstanceClass": "db.t3.micro",
          "Engine": "postgres",
          "EngineVersion": "17.10",
          "AllocatedStorage": "20",
          "MultiAZ": false,
          "MasterUsername": "dbadmin",
          "MasterUserPassword": {
            "Fn::Sub": "{{resolve:secretsmanager:${AppDBSecret}:SecretString:password}}"
          },
          "StorageEncrypted": false,
          "BackupRetentionPeriod": 0,
          "DeletionProtection": false,
          "DBSubnetGroupName": {
            "Ref": "AppDBSubnetGroup"
          },
          "VPCSecurityGroups": [
            {
              "Fn::ImportValue": "rs-infra-DbSg-GroupId"
            }
          ]
        }
      }
    },
    "Outputs": {
      "AppDBEndpoint": {
        "Value": {
          "Fn::GetAtt": [
            "AppDB",
            "Endpoint.Address"
          ]
        },
        "Export": {
          "Name": "rs-db-AppDB-Endpoint"
        }
      },
      "AppDBPort": {
        "Value": {
          "Fn::GetAtt": [
            "AppDB",
            "Endpoint.Port"
          ]
        },
        "Export": {
          "Name": "rs-db-AppDB-Port"
        }
      },
      "AppDBSecretArn": {
        "Value": {
          "Ref": "AppDBSecret"
        },
        "Export": {
          "Name": "rs-db-AppDB-SecretArn"
        }
      }
    }
  },
  "rs-compute": {
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "Stack rs-compute — gerada pelo iacmp",
    "Resources": {
      "MigrationFn": {
        "Type": "AWS::Lambda::Function",
        "Properties": {
          "FunctionName": "MigrationFn",
          "Runtime": "nodejs20.x",
          "Handler": "migrate.handler",
          "Code": "dist/",
          "MemorySize": 128,
          "Timeout": 30,
          "Role": {
            "Fn::GetAtt": [
              "MigrationPolicyRole",
              "Arn"
            ]
          },
          "Environment": {
            "Variables": {
              "DB_HOST": {
                "Fn::ImportValue": "rs-db-AppDB-Endpoint"
              },
              "DB_PORT": {
                "Fn::ImportValue": "rs-db-AppDB-Port"
              },
              "DB_PASSWORD": "{{resolve:secretsmanager:rs-db-AppDB-db-password:SecretString:password}}"
            }
          },
          "VpcConfig": {
            "SubnetIds": [
              {
                "Fn::ImportValue": "rs-infra-LambdaSubnet1-SubnetId"
              }
            ],
            "SecurityGroupIds": [
              {
                "Fn::ImportValue": "rs-infra-LambdaSg-GroupId"
              }
            ]
          }
        }
      },
      "MigrationPolicyRole": {
        "Type": "AWS::IAM::Role",
        "Properties": {
          "RoleName": {
            "Fn::Sub": "MigrationFn-role-${AWS::StackName}"
          },
          "AssumeRolePolicyDocument": {
            "Version": "2012-10-17",
            "Statement": [
              {
                "Effect": "Allow",
                "Principal": {
                  "Service": "lambda.amazonaws.com"
                },
                "Action": "sts:AssumeRole"
              }
            ]
          },
          "ManagedPolicyArns": [
            "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole"
          ],
          "Policies": [
            {
              "PolicyName": "MigrationPolicy",
              "PolicyDocument": {
                "Version": "2012-10-17",
                "Statement": [
                  {
                    "Effect": "Allow",
                    "Action": [
                      "secretsmanager:GetSecretValue"
                    ],
                    "Resource": [
                      {
                        "Fn::ImportValue": "rs-db-AppDB-SecretArn"
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "Tags": [
            {
              "Key": "Name",
              "Value": "MigrationPolicyRole"
            }
          ]
        }
      }
    },
    "Outputs": {
      "MigrationFnArn": {
        "Value": {
          "Fn::GetAtt": [
            "MigrationFn",
            "Arn"
          ]
        },
        "Export": {
          "Name": "rs-compute-MigrationFn-Arn"
        }
      },
      "MigrationFnName": {
        "Value": {
          "Ref": "MigrationFn"
        },
        "Export": {
          "Name": "rs-compute-MigrationFn-Name"
        }
      },
      "MigrationPolicyRoleRoleArn": {
        "Value": {
          "Fn::GetAtt": [
            "MigrationPolicyRole",
            "Arn"
          ]
        },
        "Export": {
          "Name": "rs-compute-MigrationPolicyRole-RoleArn"
        }
      }
    }
  }
}
