{
  "rs-infra": {
    "terraform": {
      "required_providers": {
        "aws": {
          "source": "hashicorp/aws",
          "version": "~> 5.0"
        }
      }
    },
    "provider": {
      "aws": {
        "region": "${var.aws_region}"
      }
    },
    "variable": {
      "aws_region": {
        "type": "string",
        "default": "us-east-1"
      }
    },
    "resource": {
      "aws_vpc": {
        "appvpc": {
          "cidr_block": "10.0.0.0/16",
          "enable_dns_hostnames": true,
          "enable_dns_support": true
        }
      },
      "aws_subnet": {
        "dbsubnet1": {
          "vpc_id": "${aws_vpc.appvpc.id}",
          "cidr_block": "10.0.1.0/24",
          "availability_zone": "us-east-1a",
          "map_public_ip_on_launch": false
        },
        "dbsubnet2": {
          "vpc_id": "${aws_vpc.appvpc.id}",
          "cidr_block": "10.0.2.0/24",
          "availability_zone": "us-east-1b",
          "map_public_ip_on_launch": false
        },
        "lambdasubnet1": {
          "vpc_id": "${aws_vpc.appvpc.id}",
          "cidr_block": "10.0.3.0/24",
          "availability_zone": "us-east-1c",
          "map_public_ip_on_launch": false
        }
      },
      "aws_security_group": {
        "dbsg": {
          "description": "db",
          "vpc_id": "${aws_vpc.appvpc.id}",
          "ingress": [
            {
              "description": "",
              "from_port": 5432,
              "to_port": 5432,
              "protocol": "tcp",
              "cidr_blocks": [
                "10.0.0.0/16"
              ],
              "ipv6_cidr_blocks": [],
              "prefix_list_ids": [],
              "security_groups": [],
              "self": false
            }
          ],
          "egress": [
            {
              "description": "Allow all egress",
              "from_port": 0,
              "to_port": 0,
              "protocol": "-1",
              "cidr_blocks": [
                "0.0.0.0/0"
              ],
              "ipv6_cidr_blocks": [],
              "prefix_list_ids": [],
              "security_groups": [],
              "self": false
            }
          ]
        },
        "lambdasg": {
          "description": "lambda",
          "vpc_id": "${aws_vpc.appvpc.id}",
          "ingress": [],
          "egress": [
            {
              "description": "Allow all egress",
              "from_port": 0,
              "to_port": 0,
              "protocol": "-1",
              "cidr_blocks": [
                "0.0.0.0/0"
              ],
              "ipv6_cidr_blocks": [],
              "prefix_list_ids": [],
              "security_groups": [],
              "self": false
            }
          ]
        }
      }
    },
    "output": {
      "AppVpcVpcId": {
        "value": "${aws_vpc.appvpc.id}",
        "description": "rs-infra-AppVpc-VpcId"
      },
      "DbSubnet1SubnetId": {
        "value": "${aws_subnet.dbsubnet1.id}",
        "description": "rs-infra-DbSubnet1-SubnetId"
      },
      "DbSubnet2SubnetId": {
        "value": "${aws_subnet.dbsubnet2.id}",
        "description": "rs-infra-DbSubnet2-SubnetId"
      },
      "LambdaSubnet1SubnetId": {
        "value": "${aws_subnet.lambdasubnet1.id}",
        "description": "rs-infra-LambdaSubnet1-SubnetId"
      },
      "DbSgGroupId": {
        "value": "${aws_security_group.dbsg.id}",
        "description": "rs-infra-DbSg-GroupId"
      },
      "LambdaSgGroupId": {
        "value": "${aws_security_group.lambdasg.id}",
        "description": "rs-infra-LambdaSg-GroupId"
      }
    }
  },
  "rs-db": {
    "terraform": {
      "required_providers": {
        "aws": {
          "source": "hashicorp/aws",
          "version": "~> 5.0"
        }
      }
    },
    "provider": {
      "aws": {
        "region": "${var.aws_region}"
      }
    },
    "variable": {
      "aws_region": {
        "type": "string",
        "default": "us-east-1"
      },
      "rs_infra_dbsubnet1_subnetid": {
        "type": "string"
      },
      "rs_infra_dbsubnet2_subnetid": {
        "type": "string"
      },
      "rs_infra_dbsg_groupid": {
        "type": "string"
      }
    },
    "resource": {
      "aws_secretsmanager_secret": {
        "appdbsecret": {
          "name": "rs-db-AppDB-db-password"
        }
      },
      "aws_db_subnet_group": {
        "appdbsubnetgroup": {
          "description": "Subnet group para AppDB",
          "subnet_ids": [
            "${var.rs_infra_dbsubnet1_subnetid}",
            "${var.rs_infra_dbsubnet2_subnetid}"
          ]
        }
      },
      "aws_db_instance": {
        "appdb": {
          "instance_class": "db.t3.micro",
          "engine": "postgres",
          "engine_version": "17.10",
          "allocated_storage": "20",
          "multi_az": false,
          "username": "dbadmin",
          "password": "{{resolve:secretsmanager:${aws_secretsmanager_secret.appdbsecret.arn}:SecretString:password}}",
          "storage_encrypted": false,
          "backup_retention_period": 0,
          "deletion_protection": false,
          "db_subnet_group_name": "${aws_db_subnet_group.appdbsubnetgroup.id}",
          "vpc_security_group_ids": [
            "${var.rs_infra_dbsg_groupid}"
          ]
        }
      }
    },
    "output": {
      "AppDBEndpoint": {
        "value": "${aws_db_instance.appdb.address}",
        "description": "rs-db-AppDB-Endpoint"
      },
      "AppDBPort": {
        "value": "${aws_db_instance.appdb.port}",
        "description": "rs-db-AppDB-Port"
      },
      "AppDBSecretArn": {
        "value": "${aws_secretsmanager_secret.appdbsecret.arn}",
        "description": "rs-db-AppDB-SecretArn"
      }
    }
  },
  "rs-compute": {
    "terraform": {
      "required_providers": {
        "aws": {
          "source": "hashicorp/aws",
          "version": "~> 5.0"
        },
        "archive": {
          "source": "hashicorp/archive",
          "version": "~> 2.0"
        }
      }
    },
    "provider": {
      "aws": {
        "region": "${var.aws_region}"
      }
    },
    "variable": {
      "aws_region": {
        "type": "string",
        "default": "us-east-1"
      },
      "rs_db_appdb_endpoint": {
        "type": "string"
      },
      "rs_db_appdb_port": {
        "type": "string"
      },
      "rs_infra_lambdasubnet1_subnetid": {
        "type": "string"
      },
      "rs_infra_lambdasg_groupid": {
        "type": "string"
      },
      "rs_db_appdb_secretarn": {
        "type": "string"
      }
    },
    "data": {
      "archive_file": {
        "migrationfn_archive": {
          "type": "zip",
          "source_dir": "dist/",
          "output_path": "migrationfn.zip"
        }
      }
    },
    "resource": {
      "aws_lambda_function": {
        "migrationfn": {
          "function_name": "MigrationFn",
          "runtime": "nodejs20.x",
          "handler": "migrate.handler",
          "filename": "${data.archive_file.migrationfn_archive.output_path}",
          "source_code_hash": "${data.archive_file.migrationfn_archive.output_base64sha256}",
          "memory_size": 128,
          "timeout": 30,
          "role": "${aws_iam_role.migrationpolicyrole.arn}",
          "environment": {
            "variables": {
              "DB_HOST": "${var.rs_db_appdb_endpoint}",
              "DB_PORT": "${var.rs_db_appdb_port}",
              "DB_PASSWORD": "{{resolve:secretsmanager:rs-db-AppDB-db-password:SecretString:password}}"
            }
          },
          "vpc_config": {
            "subnet_ids": [
              "${var.rs_infra_lambdasubnet1_subnetid}"
            ],
            "security_group_ids": [
              "${var.rs_infra_lambdasg_groupid}"
            ]
          }
        }
      },
      "aws_iam_role": {
        "migrationpolicyrole": {
          "name": "MigrationFn-role-iacmp",
          "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}",
          "managed_policy_arns": [
            "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole"
          ],
          "inline_policy": [
            {
              "name": "MigrationPolicy",
              "policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":[\"secretsmanager:GetSecretValue\"],\"Resource\":[\"${var.rs_db_appdb_secretarn}\"]}]}"
            }
          ]
        }
      }
    },
    "output": {
      "MigrationFnArn": {
        "value": "${aws_lambda_function.migrationfn.arn}",
        "description": "rs-compute-MigrationFn-Arn"
      },
      "MigrationPolicyRoleRoleArn": {
        "value": "${aws_iam_role.migrationpolicyrole.arn}",
        "description": "rs-compute-MigrationPolicyRole-RoleArn"
      }
    }
  }
}
