{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "archive": {
        "source": "hashicorp/archive",
        "version": "~> 2.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "${var.aws_region}"
    }
  },
  "variable": {
    "aws_region": {
      "type": "string",
      "default": "us-east-1"
    }
  },
  "data": {
    "archive_file": {
      "producerfn_archive": {
        "type": "zip",
        "source_dir": "dist/",
        "output_path": "producerfn.zip"
      },
      "consumerfn_archive": {
        "type": "zip",
        "source_dir": "dist/",
        "output_path": "consumerfn.zip"
      }
    }
  },
  "resource": {
    "aws_kinesis_stream": {
      "eventstream": {
        "name": "EventStream",
        "shard_count": 1,
        "retention_period": 24
      }
    },
    "aws_lambda_function": {
      "producerfn": {
        "function_name": "ProducerFn",
        "runtime": "nodejs20.x",
        "handler": "producer.handler",
        "filename": "${data.archive_file.producerfn_archive.output_path}",
        "source_code_hash": "${data.archive_file.producerfn_archive.output_base64sha256}",
        "memory_size": 128,
        "timeout": 30,
        "role": "${aws_iam_role.producerpolicyrole.arn}",
        "environment": {
          "variables": {
            "STREAM_NAME": "${aws_kinesis_stream.eventstream.name}"
          }
        }
      },
      "consumerfn": {
        "function_name": "ConsumerFn",
        "runtime": "nodejs20.x",
        "handler": "consumer.handler",
        "filename": "${data.archive_file.consumerfn_archive.output_path}",
        "source_code_hash": "${data.archive_file.consumerfn_archive.output_base64sha256}",
        "memory_size": 128,
        "timeout": 30,
        "role": "${aws_iam_role.consumerfndefaultrole.arn}"
      }
    },
    "aws_iam_role": {
      "producerpolicyrole": {
        "name": "ProducerFn-role-iacmp",
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}",
        "managed_policy_arns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ],
        "inline_policy": [
          {
            "name": "ProducerPolicy",
            "policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":[\"kinesis:PutRecord\",\"kinesis:PutRecords\"],\"Resource\":[\"${aws_kinesis_stream.eventstream.arn}\"]}]}"
          }
        ]
      },
      "consumerfndefaultrole": {
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}",
        "managed_policy_arns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole",
          "arn:aws:iam::aws:policy/service-role/AWSLambdaKinesisExecutionRole"
        ]
      }
    },
    "aws_lambda_event_source_mapping": {
      "consumerfneventsource1": {
        "event_source_arn": "${aws_kinesis_stream.eventstream.arn}",
        "function_name": "${aws_lambda_function.consumerfn.function_name}",
        "batch_size": 100,
        "starting_position": "TRIM_HORIZON"
      }
    }
  },
  "output": {
    "EventStreamArn": {
      "value": "${aws_kinesis_stream.eventstream.arn}",
      "description": "kinesis-stream-EventStream-Arn"
    },
    "ProducerFnArn": {
      "value": "${aws_lambda_function.producerfn.arn}",
      "description": "kinesis-stream-ProducerFn-Arn"
    },
    "ProducerFnName": {
      "value": "${aws_lambda_function.producerfn.function_name}",
      "description": "kinesis-stream-ProducerFn-Name"
    },
    "ProducerPolicyRoleRoleArn": {
      "value": "${aws_iam_role.producerpolicyrole.arn}",
      "description": "kinesis-stream-ProducerPolicyRole-RoleArn"
    },
    "ConsumerFnArn": {
      "value": "${aws_lambda_function.consumerfn.arn}",
      "description": "kinesis-stream-ConsumerFn-Arn"
    },
    "ConsumerFnName": {
      "value": "${aws_lambda_function.consumerfn.function_name}",
      "description": "kinesis-stream-ConsumerFn-Name"
    }
  }
}
