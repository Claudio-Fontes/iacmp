{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "${var.aws_region}"
    }
  },
  "variable": {
    "aws_region": {
      "type": "string",
      "default": "us-east-1"
    }
  },
  "data": {
    "aws_caller_identity": {
      "current": {}
    }
  },
  "resource": {
    "aws_iam_role": {
      "processfndefaultrole": {
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}",
        "managed_policy_arns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      }
    },
    "aws_lambda_function": {
      "processfn": {
        "function_name": "ProcessFn",
        "runtime": "nodejs20.x",
        "handler": "index.handler",
        "filename": "dist/",
        "memory_size": 128,
        "timeout": 30,
        "role": "${aws_iam_role.processfndefaultrole.arn}",
        "environment": {
          "variables": {
            "DEST_BUCKET": "${aws_s3_bucket.outputbucket.bucket}"
          }
        }
      }
    },
    "aws_s3_bucket": {
      "inputbucket": {
        "versioning_configuration": {
          "Status": "Enabled"
        },
        "public_access_block_configuration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "notification_configuration": {
          "LambdaConfigurations": [
            {
              "Event": "s3:ObjectCreated:*",
              "Function": "${aws_lambda_function.processfn.arn}"
            }
          ]
        },
        "depends_on": [
          "aws_lambda_permission.inputbucketinvokepermission0"
        ],
        "lifecycle": {
          "prevent_destroy": true
        }
      },
      "outputbucket": {
        "versioning_configuration": {
          "Status": "Suspended"
        },
        "public_access_block_configuration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "lifecycle": {
          "prevent_destroy": true
        }
      }
    },
    "aws_lambda_permission": {
      "inputbucketinvokepermission0": {
        "action": "lambda:InvokeFunction",
        "function_name": "${aws_lambda_function.processfn.arn}",
        "principal": "s3.amazonaws.com",
        "source_account": "${data.aws_caller_identity.current.account_id}"
      }
    }
  },
  "output": {
    "ProcessFnArn": {
      "value": "${aws_lambda_function.processfn.arn}",
      "description": "s3-lambda-pipeline-ProcessFn-Arn"
    },
    "InputBucketName": {
      "value": "${aws_s3_bucket.inputbucket.bucket}",
      "description": "s3-lambda-pipeline-InputBucket-Name"
    },
    "InputBucketArn": {
      "value": "${aws_s3_bucket.inputbucket.arn}",
      "description": "s3-lambda-pipeline-InputBucket-Arn"
    },
    "OutputBucketName": {
      "value": "${aws_s3_bucket.outputbucket.bucket}",
      "description": "s3-lambda-pipeline-OutputBucket-Name"
    },
    "OutputBucketArn": {
      "value": "${aws_s3_bucket.outputbucket.arn}",
      "description": "s3-lambda-pipeline-OutputBucket-Arn"
    }
  }
}
