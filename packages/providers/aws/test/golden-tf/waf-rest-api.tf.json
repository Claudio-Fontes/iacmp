{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "archive": {
        "source": "hashicorp/archive",
        "version": "~> 2.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "${var.aws_region}"
    }
  },
  "variable": {
    "aws_region": {
      "type": "string",
      "default": "us-east-1"
    }
  },
  "data": {
    "archive_file": {
      "apihandler_archive": {
        "type": "zip",
        "source_dir": "dist/",
        "output_path": "apihandler.zip"
      }
    },
    "aws_region": {
      "current": {}
    },
    "aws_caller_identity": {
      "current": {}
    }
  },
  "resource": {
    "aws_wafv2_web_acl": {
      "apiwaf": {
        "name": "ApiWaf",
        "scope": "REGIONAL",
        "default_action": {
          "allow": {}
        },
        "description": "WAF ApiWaf",
        "rule": [
          {
            "name": "RateLimit",
            "priority": 1,
            "action": {
              "block": {}
            },
            "visibility_config": {
              "sampled_requests_enabled": true,
              "cloudwatch_metrics_enabled": true,
              "metric_name": "RateLimit"
            },
            "statement": {
              "rate_based_statement": {
                "limit": 1000,
                "aggregate_key_type": "IP"
              }
            }
          },
          {
            "name": "CommonRules",
            "priority": 2,
            "override_action": {
              "none": {}
            },
            "visibility_config": {
              "sampled_requests_enabled": true,
              "cloudwatch_metrics_enabled": true,
              "metric_name": "CommonRules"
            },
            "statement": {
              "managed_rule_group_statement": {
                "vendor_name": "AWS",
                "name": "AWSManagedRulesCommonRuleSet"
              }
            }
          }
        ],
        "visibility_config": {
          "sampled_requests_enabled": true,
          "cloudwatch_metrics_enabled": true,
          "metric_name": "ApiWaf"
        }
      }
    },
    "aws_iam_role": {
      "apihandlerdefaultrole": {
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"},\"Action\":\"sts:AssumeRole\"}]}",
        "managed_policy_arns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
        ]
      }
    },
    "aws_lambda_function": {
      "apihandler": {
        "function_name": "ApiHandler",
        "runtime": "nodejs20.x",
        "handler": "index.handler",
        "filename": "${data.archive_file.apihandler_archive.output_path}",
        "source_code_hash": "${data.archive_file.apihandler_archive.output_base64sha256}",
        "memory_size": 128,
        "timeout": 30,
        "role": "${aws_iam_role.apihandlerdefaultrole.arn}"
      }
    },
    "aws_api_gateway_rest_api": {
      "restapi": {
        "name": "waf-api"
      }
    },
    "aws_api_gateway_resource": {
      "restapiresourceitems": {
        "rest_api_id": "${aws_api_gateway_rest_api.restapi.id}",
        "parent_id": "${aws_api_gateway_rest_api.restapi.root_resource_id}",
        "path_part": "items"
      }
    },
    "aws_api_gateway_method": {
      "restapigetitemsmethod": {
        "rest_api_id": "${aws_api_gateway_rest_api.restapi.id}",
        "resource_id": "${aws_api_gateway_resource.restapiresourceitems.id}",
        "http_method": "GET",
        "authorization": "NONE"
      },
      "restapipostitemsmethod": {
        "rest_api_id": "${aws_api_gateway_rest_api.restapi.id}",
        "resource_id": "${aws_api_gateway_resource.restapiresourceitems.id}",
        "http_method": "POST",
        "authorization": "NONE"
      }
    },
    "aws_api_gateway_integration": {
      "restapigetitemsmethod_integration": {
        "rest_api_id": "${aws_api_gateway_rest_api.restapi.id}",
        "resource_id": "${aws_api_gateway_resource.restapiresourceitems.id}",
        "http_method": "GET",
        "type": "AWS_PROXY",
        "integration_http_method": "POST",
        "uri": "arn:aws:apigateway:${data.aws_region.current.name}:lambda:path/2015-03-31/functions/${aws_lambda_function.apihandler.arn}/invocations"
      },
      "restapipostitemsmethod_integration": {
        "rest_api_id": "${aws_api_gateway_rest_api.restapi.id}",
        "resource_id": "${aws_api_gateway_resource.restapiresourceitems.id}",
        "http_method": "POST",
        "type": "AWS_PROXY",
        "integration_http_method": "POST",
        "uri": "arn:aws:apigateway:${data.aws_region.current.name}:lambda:path/2015-03-31/functions/${aws_lambda_function.apihandler.arn}/invocations"
      }
    },
    "aws_api_gateway_deployment": {
      "restapideploymente11612c6": {
        "rest_api_id": "${aws_api_gateway_rest_api.restapi.id}",
        "depends_on": [
          "aws_api_gateway_method.restapigetitemsmethod",
          "aws_api_gateway_method.restapipostitemsmethod"
        ]
      }
    },
    "aws_api_gateway_stage": {
      "restapistage": {
        "rest_api_id": "${aws_api_gateway_rest_api.restapi.id}",
        "deployment_id": "${aws_api_gateway_deployment.restapideploymente11612c6.id}",
        "stage_name": "prod"
      }
    },
    "aws_wafv2_web_acl_association": {
      "restapiwafassociation": {
        "resource_arn": "arn:aws:apigateway:${data.aws_region.current.name}::/restapis/${aws_api_gateway_rest_api.restapi.id}/stages/prod",
        "web_acl_arn": "${aws_wafv2_web_acl.apiwaf.arn}",
        "depends_on": [
          "aws_api_gateway_stage.restapistage"
        ]
      }
    },
    "aws_lambda_permission": {
      "apihandlerrestapipermission": {
        "action": "lambda:InvokeFunction",
        "function_name": "${aws_lambda_function.apihandler.arn}",
        "principal": "apigateway.amazonaws.com",
        "source_arn": "arn:aws:execute-api:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:${aws_api_gateway_rest_api.restapi.id}/*/*"
      }
    }
  },
  "output": {
    "ApiWafArn": {
      "value": "${aws_wafv2_web_acl.apiwaf.arn}",
      "description": "waf-rest-api-ApiWaf-Arn"
    },
    "ApiHandlerArn": {
      "value": "${aws_lambda_function.apihandler.arn}",
      "description": "waf-rest-api-ApiHandler-Arn"
    },
    "ApiHandlerName": {
      "value": "${aws_lambda_function.apihandler.function_name}",
      "description": "waf-rest-api-ApiHandler-Name"
    },
    "ApiUrl": {
      "value": "https://${aws_api_gateway_rest_api.restapi.id}.execute-api.${data.aws_region.current.name}.amazonaws.com/prod",
      "description": "waf-rest-api-RestApi-ApiUrl"
    }
  }
}
