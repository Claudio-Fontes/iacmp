{
  "name": "iacmp",
  "version": "1.2.0",
  "description": "IaC Multi Plataforma — CLI inteligente para AWS, Azure, GCP e Terraform com geração de stacks via IA",
  "keywords": [
    "iac",
    "cli",
    "aws",
    "azure",
    "gcp",
    "terraform",
    "ai",
    "devops",
    "infrastructure",
    "cdk"
  ],
  "author": "Claudio Melo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Claudio-Fontes/iacmp"
  },
  "homepage": "https://github.com/Claudio-Fontes/iacmp#readme",
  "bugs": {
    "url": "https://github.com/Claudio-Fontes/iacmp/issues"
  },
  "bin": {
    "iacmp": "./bin/run.js"
  },
  "main": "dist/index.js",
  "files": [
    "/bin/run.js",
    "/dist",
    "/oclif.manifest.json",
    "/LICENSE"
  ],
  "scripts": {
    "build": "tsup && oclif manifest",
    "manifest": "oclif manifest",
    "prepack": "cp ../../LICENSE ./LICENSE && tsup && oclif manifest",
    "dev": "tsup --watch",
    "clean": "rm -rf dist oclif.manifest.json",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@iacmp/core": "^1.2.0",
    "@oclif/core": "^4.0.0",
    "chalk": "^4.1.2",
    "diff": "^5.2.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@iacmp/ai": "*",
    "@iacmp/dashboard": "*",
    "@iacmp/plugin-sdk": "*",
    "@iacmp/provider-aws": "*",
    "@iacmp/provider-azure": "*",
    "@iacmp/provider-gcp": "*",
    "@iacmp/provider-terraform": "*",
    "@iacmp/registry": "*",
    "@oclif/dev-cli": "^1.26.10",
    "@types/diff": "^5.2.1",
    "@types/jest": "^29",
    "@types/node": "^20",
    "jest": "^29",
    "oclif": "^4.0.0",
    "ts-jest": "^29",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "oclif": {
    "bin": "iacmp",
    "dirname": "iacmp",
    "commands": "./dist/commands",
    "helpClass": "./dist/help.js",
    "plugins": []
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "testTimeout": 30000,
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  }
}
