{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": [
      "es2022"
    ],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@iacmp/core": [
        "/Users/cmelo/Projetos/iacmp/packages/core"
      ],
      "@iacmp/core/*": [
        "/Users/cmelo/Projetos/iacmp/packages/core/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
