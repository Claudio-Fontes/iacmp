# Chaves de API utilizadas pelo `iacmp ai` — copie para `.env` e preencha.
# `.env` esta no `.gitignore`; nunca commite a copia preenchida.

# Anthropic (Claude). Tem prioridade sobre GITHUB_TOKEN quando ambos estao setados.
# Obter em https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GitHub (Copilot) — fallback quando ANTHROPIC_API_KEY nao esta setado.
# Precisa de um token com acesso ao Copilot (`copilot` scope).
GITHUB_TOKEN=

# Idioma da interface do chat e da resposta do Claude (pt|en|es). Default: pt.
# Pode ser trocado em runtime no chat com /lang pt|en|es.
IACMP_LANG=

# Voz no chat (/voz) — STT local via whisper.cpp. Requer o binario sox e o
# binario+modelo do whisper.cpp instalados localmente. Rode `iacmp doctor --fix`
# para instalar e configurar automaticamente (mac/linux/windows, com confirmacao
# antes de cada acao) — ele tambem baixa um modelo padrao e preenche
# IACMP_WHISPER_MODEL abaixo. Rode `iacmp doctor` (sem --fix) so para checar.
# Caminho do binario whisper.cpp (whisper-cli/main). Default: procura no PATH.
IACMP_WHISPER_BIN=
# Caminho do modelo ggml do whisper.cpp (obrigatorio para usar /voz).
IACMP_WHISPER_MODEL=
